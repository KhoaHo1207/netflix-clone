// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String @id @default(uuid())
  supabaseUserId String @unique
  email          String @unique
  role           String @default("USER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles Profile[]
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  avatar    String? // URL to avatar image
  isKids    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  myList MyList[]
}

model Movie {
  id             String   @id @default(cuid())
  publicId       String   @unique // url friendly id
  title          String
  description    String
  thumbnailUrl   String? // Cloudinary authenticated delivery URL
  isTrending     Boolean  @default(false)
  trailerUrl     String? // YouTube trailer URL for preview
  videoUrl       String? // Cloudinary authenticated delivery URL
  cloudinaryId   String? // Cloudinary asset public_id (e.g. "movies/abc") — used for signed URL generation
  duration       Int? // in seconds
  releaseYear    Int?
  maturityRating String?  @default("NR")
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())

  myList MyList[]
}

model MyList {
  id        String   @id @default(cuid())
  profileId String
  movieId   String?
  addedAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  movie   Movie?  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([profileId, movieId])
}
